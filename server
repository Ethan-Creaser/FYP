#!/usr/bin/env python3
"""
server.py — UWB Localisation Gateway Server
=============================================
Reads JSON lines from Node 0 over USB serial, maintains a live node map,
and pushes updates to map.html via WebSocket.

Requirements:
    pip install pyserial websockets

Usage:
    python server.py                         # auto-detect serial port
    python server.py --port COM3             # Windows
    python server.py --port /dev/ttyACM0    # Linux
    python server.py --port /dev/cu.usbmodem101  # Mac
"""

import argparse, asyncio, json, sys, time, threading, os
import serial, serial.tools.list_ports
import websockets
from http.server import HTTPServer, SimpleHTTPRequestHandler

WS_HOST   = "localhost"
WS_PORT   = 8765
HTTP_PORT = 8080
BAUD      = 115200
STALE_S   = 120

node_map   = {}
_clients   = set()
_map_lock  = threading.Lock()

def auto_port():
    ports = list(serial.tools.list_ports.comports())
    for p in ports:
        desc = p.description.upper()
        if any(k in desc for k in ("USB","ACM","SILABS","CH340","FTDI","CP210")):
            return p.device
    return ports[0].device if ports else None

def serial_thread(port, loop, bcast):
    print("[Serial] Connecting to {} @ {} baud...".format(port, BAUD))
    while True:
        try:
            with serial.Serial(port, BAUD, timeout=1) as ser:
                print("[Serial] Connected to {}".format(port))
                while True:
                    raw = ser.readline()
                    if not raw:
                        continue
                    line = raw.decode("utf-8", errors="replace").strip()
                    if not line:
                        continue
                    if not line.startswith("{"):
                        print("[Node0]", line)
                        continue
                    try:
                        msg = json.loads(line)
                    except json.JSONDecodeError:
                        print("[Node0]", line)
                        continue
                    if msg.get("type") == "OFFLINE":
                        nid = msg.get("id")
                        if nid is not None:
                            with _map_lock:
                                node_map.pop(nid, None)
                            print("[Map] Node {} went offline".format(nid))
                            asyncio.run_coroutine_threadsafe(
                                broadcast_stale([nid]), loop)
                        continue
                    if msg.get("type") != "MAP":
                        continue
                    nid = msg.get("id")
                    if nid is None:
                        continue
                    entry = {
                        "id":        nid,
                        "x":         float(msg.get("x", 0)),
                        "y":         float(msg.get("y", 0)),
                        "z":         float(msg.get("z", 0)),
                        "rssi":      int(msg.get("rssi", 0)),
                        "snr":       float(msg.get("snr", 0)),
                        "last_seen": time.time(),
                    }
                    with _map_lock:
                        node_map[nid] = entry
                    print("[Map] Node {}: ({:.3f}, {:.3f}, {:.3f})".format(
                        nid, entry["x"], entry["y"], entry["z"]))
                    asyncio.run_coroutine_threadsafe(bcast(entry), loop)
        except serial.SerialException as e:
            print("[Serial] Error:", e, "— retrying in 3s")
            time.sleep(3)

async def ws_handler(ws):
    _clients.add(ws)
    try:
        with _map_lock:
            snap = list(node_map.values())
        await ws.send(json.dumps({"type":"SNAPSHOT","nodes":snap}))
        async for _ in ws:
            pass
    except websockets.exceptions.ConnectionClosed:
        pass
    finally:
        _clients.discard(ws)

async def broadcast(entry):
    if not _clients:
        return
    msg = json.dumps({"type":"MAP", **entry})
    await asyncio.gather(*[c.send(msg) for c in list(_clients)], return_exceptions=True)

async def broadcast_stale(ids):
    if not _clients:
        return
    msg = json.dumps({"type":"STALE","ids":ids})
    await asyncio.gather(*[c.send(msg) for c in list(_clients)], return_exceptions=True)

async def stale_cleaner():
    while True:
        await asyncio.sleep(30)
        cutoff = time.time() - STALE_S
        with _map_lock:
            stale = [nid for nid,e in node_map.items() if e["last_seen"] < cutoff]
            for nid in stale:
                del node_map[nid]
                print("[Map] Node {} stale — removed".format(nid))
        if stale and _clients:
            msg = json.dumps({"type":"STALE","ids":stale})
            await asyncio.gather(*[c.send(msg) for c in list(_clients)], return_exceptions=True)

def http_thread():
    os.chdir(os.path.dirname(os.path.abspath(__file__)))
    httpd = HTTPServer(("", HTTP_PORT), SimpleHTTPRequestHandler)
    print("[HTTP] Serving at http://localhost:{}/map.html".format(HTTP_PORT))
    httpd.serve_forever()

async def async_main(port):
    loop = asyncio.get_event_loop()
    ws_server = await websockets.serve(ws_handler, WS_HOST, WS_PORT)
    print("[WS] WebSocket server on ws://{}:{}".format(WS_HOST, WS_PORT))
    threading.Thread(target=http_thread, daemon=True).start()
    threading.Thread(target=serial_thread, args=(port, loop, broadcast), daemon=True).start()
    print("\n>>> Open http://localhost:{}/map.html in your browser\n".format(HTTP_PORT))
    await asyncio.gather(stale_cleaner(), ws_server.wait_closed())

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", default=None)
    args = ap.parse_args()
    port = args.port or auto_port()
    if not port:
        print("[ERROR] No serial port found. Use --port to specify one.")
        sys.exit(1)
    print("[Serial] Using port:", port)
    try:
        asyncio.run(async_main(port))
    except KeyboardInterrupt:
        print("\n[Server] Stopped")

if __name__ == "__main__":
    main()
